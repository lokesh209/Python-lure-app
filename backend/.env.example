# Where projects are stored. Default is a local folder so the app starts even
# when the SD/external drive is unplugged. Change to /Volumes/TOSHIBA EXT/PythonCams
# (or wherever the lab keeps the master tree) once that drive is mounted.
LURE_DATA_ROOT=~/PythonLureData
LURE_DB_PATH=./lure.db
LURE_HOST=127.0.0.1
LURE_PORT=8000
LURE_CONF_THRESHOLD=0.05
LURE_DETECTOR=mock

# --- HiPerGator (UFRC) ---
# `ssh_alias` should match an entry in your ~/.ssh/config that handles
# ControlMaster (so the app reuses one Duo-authenticated session).
HIPERGATOR_SSH_ALIAS=hpg
HIPERGATOR_REMOTE_BASE=/blue/ramccleery/makinenilokesh/lure_runs
HIPERGATOR_CONDA_ENV=/blue/ramccleery/makinenilokesh/envs/megadetector
HIPERGATOR_ACCOUNT=ramccleery
HIPERGATOR_QOS=ramccleery
HIPERGATOR_PARTITION=hpg-turin
HIPERGATOR_GRES=gpu:l4:1
HIPERGATOR_CPUS=4
HIPERGATOR_MEM=32gb
HIPERGATOR_TIME=24:00:00
HIPERGATOR_EMAIL=
HIPERGATOR_POLL_SEC=20
HIPERGATOR_KEEP_REMOTE=true
